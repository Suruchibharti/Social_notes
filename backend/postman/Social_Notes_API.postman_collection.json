{
  "info": {
    "_postman_id": "4fd00e94-4a4d-42af-ae4d-social-notes-api",
    "name": "Social Notes API",
    "description": "Postman collection for the Social Notes Platform backend. Run Register to create an account, then run Login to save the returned token into the collection variable named token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "postId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "API Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User registered successfully', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(pm.response.json().message).to.include('registered');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "username",
                  "value": "suruchi",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "suruchi@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "Password@123",
                  "type": "text"
                },
                {
                  "key": "profilePic",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/register"
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);",
                  "if (json.user?._id) pm.collectionVariables.set('userId', json.user._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"suruchi@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/login"
          }
        }
      ]
    },
    {
      "name": "Profile & Users",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Get Current Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "Update Current Profile",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "username",
                  "value": "suruchi_updated",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "suruchi@example.com",
                  "type": "text"
                },
                {
                  "key": "profilePic",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users?page=1&limit=20"
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users?search=suruchi&page=1&limit=10"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Following",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Follow User",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/follow/{{userId}}"
          }
        },
        {
          "name": "Unfollow User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/follow/{{userId}}"
          }
        },
        {
          "name": "Get My Following",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/following"
          }
        },
        {
          "name": "Get User Followers",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/followers/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Get Personalized Feed",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/posts/feed?page=1&limit=10"
          }
        },
        {
          "name": "Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.post?._id) pm.collectionVariables.set('postId', json.post._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "My First Social Note",
                  "type": "text"
                },
                {
                  "key": "content",
                  "value": "This is a sample post created from Postman.",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/posts"
          }
        },
        {
          "name": "Get Post By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/posts/{{postId}}"
          }
        },
        {
          "name": "Update Own Post",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Updated Social Note",
                  "type": "text"
                },
                {
                  "key": "content",
                  "value": "This post was updated from Postman.",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/posts/{{postId}}"
          }
        },
        {
          "name": "Delete Own Post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/posts/{{postId}}"
          }
        }
      ]
    }
  ]
}
